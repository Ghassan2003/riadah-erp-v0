# ═══════════════════════════════════════════════════════════════
# Riadah ERP v2 — Environment Configuration
# نسخ هذا الملف إلى .env وتعديل القيم حسب البيئة
# ═══════════════════════════════════════════════════════════════

# ── Django Core ──
DJANGO_SECRET_KEY=change-me-to-a-very-long-random-string-in-production
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend,frontend,yourdomain.com

# ── Database (PostgreSQL 15) ──
DB_ENGINE=django.db.backends.postgresql
DB_NAME=riadah_erp
DB_USER=riadah_user
DB_PASSWORD=change-me-strong-password
DB_HOST=db
DB_PORT=5432

# ── Redis (Cache + Celery + Channels) ──
REDIS_URL=redis://redis:6379/0
CACHE_BACKEND=django.core.cache.backends.redis.RedisCache
CACHE_LOCATION=redis://redis:6379/1
CHANNEL_LAYER_BACKEND=channels_redis.core.RedisChannelLayer
ANALYTICS_CACHE_BACKEND=django.core.cache.backends.redis.RedisCache
ANALYTICS_CACHE_LOCATION=redis://redis:6379/2

# ── Celery ──
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# ── JWT ──
JWT_ACCESS_TOKEN_LIFETIME_HOURS=2
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# ── CORS ──
CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://app.yourdomain.com

# ── Email (SMTP) ──
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=Riadah ERP <noreply@yourdomain.com

# ── Stripe (للدفع) ──
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Integration API Keys ──
SLACK_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Admin ──
ADMINS=admin@yourdomain.com
