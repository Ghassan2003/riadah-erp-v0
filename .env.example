# RIADAH ERP - Local Development Environment Variables
# Copy this file to .env and fill in your values

# Django
DJANGO_SECRET_KEY=django-insecure-erp-dev-local-change-in-production-x9k2m
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Database (SQLite for local, no need to change)
DB_ENGINE=django.db.backends.sqlite3
DB_NAME=db.sqlite3

